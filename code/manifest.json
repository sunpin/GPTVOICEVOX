{
  "manifest_version": 3,
  "name": "AI VOICEVOX Talker",
  "version": "1.4",
  "description": "ChatGPT / Grok の返答を自動検知し、CORS/CSP制限を回避してVOICEVOX・COEIROINKで自動読み上げします",
  "permissions": [
    "activeTab",
    "offscreen"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://grok.com/*",
    "https://*.grok.com/*",
    "http://localhost:50021/*",
    "http://127.0.0.1:50021/*",
    "http://localhost:50032/*",
    "http://127.0.0.1:50032/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://grok.com/*",
        "https://*.grok.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
